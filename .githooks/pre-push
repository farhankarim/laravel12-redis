#!/usr/bin/env bash
set -euo pipefail

# Usage note: set ALLOW_CHEQUEBOOK_PUSH=1 to bypass intentionally.
allow_private_push="${ALLOW_CHEQUEBOOK_PUSH:-0}"

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref}" ]] && continue

  local_branch="${local_ref#refs/heads/}"
  remote_branch="${remote_ref#refs/heads/}"

  if [[ "${local_branch}" == "chequebook-private" && "${allow_private_push}" != "1" ]]; then
    echo "✖ Push blocked: refusing to push branch 'chequebook-private'."
    echo "  If intentional, run once with: ALLOW_CHEQUEBOOK_PUSH=1 git push ..."
    exit 1
  fi

  if [[ "${remote_branch}" == "main" ]]; then
    if [[ "${remote_sha}" =~ ^0+$ ]]; then
      range="${local_sha}"
    else
      range="${remote_sha}..${local_sha}"
    fi

    changed="$(git diff --name-only "${range}" || true)"
    blocked_private='(^|/)(app/Http/Controllers/ChequebookImportController\.php|app/Jobs/ProcessChequebookChunkJob\.php|app/Services/ChequebookImport.*\.php|config/chequebook\.php|docs/redis-laravel-chequebook-tutorial\.md|.*[Cc]hequebook.*|.*cheque_book.*)$'

    if [[ -n "${changed}" ]] && echo "${changed}" | grep -Eiq "${blocked_private}"; then
      echo "✖ Push blocked: chequebook/private files detected in changes targeting main."
      exit 1
    fi
  fi
done
