APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# WARNING: Set to false in production to avoid exposing stack traces to end users.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=laravel

MYSQL_QUERY_LOG_ENABLED=true
MYSQL_QUERY_LOG_CONNECTION=mysql
MYSQL_QUERY_LOG_CHANNEL=mysql_queries
MYSQL_QUERY_LOG_LEVEL=info
MYSQL_QUERY_LOG_DAYS=14

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# Comma-separated list of queue names to monitor in the dashboard.
QUEUE_MONITORED=default,user-imports,chequebook-imports

# Use redis for the cache store so the app does not depend on a second DB table.
CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
# SECURITY: Always set a strong Redis password in non-local environments.
# Leave null only for local development when Redis is not network-exposed.
REDIS_PASSWORD=null
REDIS_PORT=6379

# Comma-separated list of trusted upstream proxy IPs (or * for any proxy).
# Required when the app runs behind a load-balancer or reverse proxy.
TRUSTED_PROXIES=

CHEQUEBOOK_COMPANY_PREFIX=qr
CHEQUEBOOK_BATCH_SIZE=500
CHEQUEBOOK_MAX_BATCH_SIZE=50000
CHEQUEBOOK_QUEUE=chequebook-imports
CHEQUEBOOK_AES_KEY=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
