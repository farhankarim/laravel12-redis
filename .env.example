# Application
APP_PORT=3000
APP_NAME="Redis NestJS Dashboard"
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/laravel12_redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Mail (SMTP)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME="Redis NestJS App"

# App URL (used for email verification links)
APP_URL=http://localhost:3000

# Queue names (comma-separated)
QUEUE_NAMES=default,user-imports,email-verifications
